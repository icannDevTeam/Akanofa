# ============================================================
# Akanofa - cPanel / Apache configuration
# ============================================================

# ---- HTTPS redirect ----------------------------------------
RewriteEngine On
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP:X-Forwarded-Proto} !=https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ---- Strip .html extension (clean URLs) --------------------
# /services -> /services.html  (internal rewrite, URL stays clean)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^([^\.]+)$ $1.html [NC,L]

# Redirect /page.html -> /page  (canonical clean URL)
RewriteCond %{THE_REQUEST} \s/+([^\s]+?)\.html[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# ---- Default document --------------------------------------
DirectoryIndex index.html

# ---- Pretty 404 (optional) ---------------------------------
# ErrorDocument 404 /index.html

# ---- Hide directory listings -------------------------------
Options -Indexes

# ---- MIME types --------------------------------------------
<IfModule mod_mime.c>
    AddType image/svg+xml             .svg
    AddType image/webp                .webp
    AddType image/avif                .avif
    AddType application/font-woff2    .woff2
</IfModule>

# ---- GZIP compression --------------------------------------
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript
    AddOutputFilterByType DEFLATE application/javascript application/json application/xml
    AddOutputFilterByType DEFLATE image/svg+xml application/xml+rss
</IfModule>

# ---- Browser caching ---------------------------------------
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresDefault                            "access plus 1 month"

    # HTML — short cache so updates appear quickly
    ExpiresByType text/html                   "access plus 1 hour"

    # CSS / JS
    ExpiresByType text/css                    "access plus 1 year"
    ExpiresByType application/javascript      "access plus 1 year"

    # Images
    ExpiresByType image/png                   "access plus 1 year"
    ExpiresByType image/jpeg                  "access plus 1 year"
    ExpiresByType image/webp                  "access plus 1 year"
    ExpiresByType image/svg+xml               "access plus 1 year"
    ExpiresByType image/x-icon                "access plus 1 year"

    # Fonts
    ExpiresByType font/woff                   "access plus 1 year"
    ExpiresByType font/woff2                  "access plus 1 year"
</IfModule>

# ---- Security headers --------------------------------------
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    Header set Cache-Control "public, max-age=3600" "expr=%{CONTENT_TYPE} =~ m#^text/html#"
    Header set Cache-Control "public, max-age=31536000, immutable" "expr=%{CONTENT_TYPE} =~ m#^image/#"
</IfModule>

# ---- Block sensitive files ---------------------------------
<FilesMatch "^\.|\.(py|md|log|sh|sql|env|bak)$">
    Require all denied
</FilesMatch>
